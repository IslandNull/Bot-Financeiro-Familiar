{
  "name": "bot-financeiro-familiar",
  "version": "0.1.0",
  "private": true,
  "description": "Clean V55 family cash contracts for Bot Financeiro.",
  "scripts": {
    "test": "node test/run-tests.js",
    "test:domain": "node test/domain.test.js",
    "test:schema": "node test/schema.test.js",
    "test:guardrails": "node test/guardrails.test.js",
    "push": "clasp push --force",
    "pull": "clasp pull",
    "open": "clasp open",
    "logs": "clasp logs --watch",
    "check": "node scripts/check-syntax.js && npm test",
    "smoke": "node scripts/smoke.js",
    "smoke:full": "node scripts/smoke.js --full --timeout-ms=120000",
    "verify": "npm run check && npm run smoke",
    "snapshot": "node scripts/clasp-run.js snapshot",
    "summary": "node scripts/clasp-run.js summary",
    "goals:preview": "node scripts/clasp-run.js goals_preview",
    "commitments:preview": "node scripts/clasp-run.js commitments_preview",
    "optional:v56:template": "node scripts/clasp-run.js optional_v56_template",
    "digest:preview": "node scripts/clasp-run.js copilot_digest_preview",
    "digest:send": "node scripts/clasp-run.js copilot_digest_send",
    "schema:upgrade:dry-run": "node scripts/clasp-run.js schema_upgrade_dry_run",
    "schema:upgrade": "node scripts/clasp-run.js schema_upgrade",
    "closing:draft": "node scripts/clasp-run.js closing_draft",
    "closing:close": "node scripts/clasp-run.js closing_close",
    "selftest": "node scripts/clasp-run.js selftest",
    "sheet:audit": "node scripts/sheet-audit.js"
  }
}
